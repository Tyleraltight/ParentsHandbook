# Authentication Keys
GOOGLE_API_KEY="your_google_api_key_here"
TMDB_API_KEY="your_tmdb_api_key_here"

# Model Configurations
BASE_PARSING_MODEL="gemini-3-flash-preview"
ANALYSIS_MODEL="gemini-3-pro-preview"

# Admin (leave empty to disable refresh feature)
ADMIN_KEY=""

# Optional: HTTP proxy for TMDB requests in CN (e.g. VPN socks/http proxy)
# Leave empty on Vercel — Vercel servers reach TMDB directly.
TMDB_PROXY_URL=""
